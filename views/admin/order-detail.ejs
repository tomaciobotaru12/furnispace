<%- include('layout', { title, activePage: 'orders' }) %>

<div style="margin-bottom:1.5rem">
  <a href="/admin/orders" class="btn btn-ghost btn-sm">← Back to Orders</a>
</div>

<!-- Meta grid -->
<div class="order-meta-grid">
  <div class="meta-block">
    <div class="meta-label">Order Number</div>
    <div class="meta-value">#<%= order.order_number %></div>
  </div>
  <div class="meta-block">
    <div class="meta-label">Date</div>
    <div class="meta-value"><%= new Date(order.created_at).toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'}) %></div>
  </div>
  <div class="meta-block">
    <div class="meta-label">Total</div>
    <div class="meta-value" style="color:var(--accent)">RON <%= Number(order.total).toFixed(2) %></div>
  </div>
  <div class="meta-block">
    <div class="meta-label">Status</div>
    <div class="meta-value"><span class="badge badge-<%= order.status %>"><%= order.status %></span></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start">

  <!-- Order items -->
  <div class="admin-card">
    <div class="admin-card-header"><h2>Items</h2></div>
    <div class="admin-table-wrap">
      <table>
        <thead>
          <tr>
            <th>Product</th>
            <th>Qty</th>
            <th>Unit Price</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:.75rem">
                <% if (item.product_image) { %>
                  <img src="<%= item.product_image %>" class="product-thumb" alt="">
                <% } %>
                <div style="font-weight:500"><%= item.product_name %></div>
              </div>
            </td>
            <td><%= item.quantity %></td>
            <td>RON <%= Number(item.price).toFixed(2) %></td>
            <td>RON <%= (item.quantity * item.price).toFixed(2) %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" style="text-align:right;font-weight:600;padding:.75rem 1rem;color:var(--muted)">Subtotal</td>
            <td style="font-weight:600;padding:.75rem 1rem">RON <%= Number(order.subtotal || order.total).toFixed(2) %></td>
          </tr>
          <% if (order.shipping) { %>
          <tr>
            <td colspan="3" style="text-align:right;padding:.5rem 1rem;color:var(--muted)">Shipping</td>
            <td style="padding:.5rem 1rem">RON <%= Number(order.shipping).toFixed(2) %></td>
          </tr>
          <% } %>
          <tr>
            <td colspan="3" style="text-align:right;font-weight:700;padding:.75rem 1rem">Total</td>
            <td style="font-weight:700;padding:.75rem 1rem;color:var(--accent);font-size:1rem">RON <%= Number(order.total).toFixed(2) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Right column -->
  <div style="display:flex;flex-direction:column;gap:1rem">

    <!-- Update status -->
    <div class="admin-card">
      <div class="admin-card-header"><h2>Update Status</h2></div>
      <form method="POST" action="/admin/orders/<%= order.order_number %>/status">
        <div class="form-group">
          <label for="status">New Status</label>
          <select name="status" id="status">
            <% ['pending','paid','processing','shipped','completed','cancelled'].forEach(s => { %>
              <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Save Status</button>
      </form>
    </div>

    <!-- Customer -->
    <div class="admin-card">
      <div class="admin-card-header"><h2>Customer</h2></div>
      <% if (billing) { %>
        <div style="line-height:1.8;font-size:.85rem">
          <div style="font-weight:600"><%= billing.first_name %> <%= billing.last_name %></div>
          <div class="td-muted"><%= billing.email %></div>
          <% if (billing.phone) { %><div class="td-muted"><%= billing.phone %></div><% } %>
        </div>
        <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);font-size:.85rem;line-height:1.8">
          <div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:.4rem;font-weight:600">Shipping Address</div>
          <div><%= billing.address %></div>
          <div><%= billing.city %><% if (billing.county) { %>, <%= billing.county %><% } %></div>
          <div><%= billing.postal_code %> <%= billing.country %></div>
        </div>
      <% } else { %>
        <span class="td-muted">No billing info.</span>
      <% } %>
    </div>

    <!-- Payment -->
    <div class="admin-card">
      <div class="admin-card-header"><h2>Payment</h2></div>
      <div style="font-size:.85rem;line-height:2">
        <div><span style="color:var(--muted)">Method:</span> <%= order.payment_method || 'Stripe' %></div>
        <% if (order.stripe_payment_id) { %>
          <div><span style="color:var(--muted)">Intent:</span> <span style="font-size:.75rem;font-family:monospace"><%= order.stripe_payment_id %></span></div>
        <% } %>
        <% if (order.notes) { %>
          <div style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--border)"><span style="color:var(--muted)">Notes:</span> <%= order.notes %></div>
        <% } %>
      </div>
    </div>

  </div>
</div>

<%- include('layout-end') %>
