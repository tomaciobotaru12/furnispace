<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="hero hero-sm">
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <h1 data-aos="fade-up">Our Story</h1>
    <p data-aos="fade-up" data-aos-delay="100">Making sustainable design accessible to every home.</p>
  </div>
</section>

<section class="section about-intro">
  <div class="container about-layout">
    <div data-aos="fade-right">
      <h2>Who We Are</h2>
      <p>FurniSpace was born from a simple idea: that beautifully designed, responsibly made furniture shouldn't cost the earth — literally or figuratively. We work with small workshops and independent craftspeople across Europe who share our commitment to quality and sustainability.</p>
      <p style="margin-top:1rem">Every piece in our collection is designed to last a lifetime, not a season. We carefully select materials, finishes and construction methods that minimise environmental impact while maximising the joy of living with truly beautiful furniture.</p>
    </div>
    <div data-aos="fade-left" class="about-image-wrap">
      <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&q=80" alt="Our workshop" loading="lazy">
    </div>
  </div>
</section>

<!-- Values -->
<section class="section values-section" style="background:var(--color-light)">
  <div class="container">
    <h2 class="section-title" data-aos="fade-up">What We Stand For</h2>
    <div class="values-grid">
      <div class="value-card" data-aos="fade-up" data-aos-delay="0">
        <span class="value-icon">🌿</span>
        <h3>Sustainability</h3>
        <p>FSC-certified wood, recycled materials, and carbon-offset shipping on every order.</p>
      </div>
      <div class="value-card" data-aos="fade-up" data-aos-delay="100">
        <span class="value-icon">✏️</span>
        <h3>Thoughtful Design</h3>
        <p>Every curve, joint and finish is considered. Good design should feel effortless.</p>
      </div>
      <div class="value-card" data-aos="fade-up" data-aos-delay="200">
        <span class="value-icon">🤝</span>
        <h3>Trust & Transparency</h3>
        <p>We share where our materials come from and who makes them. No greenwashing.</p>
      </div>
      <div class="value-card" data-aos="fade-up" data-aos-delay="300">
        <span class="value-icon">🚚</span>
        <h3>White-glove Delivery</h3>
        <p>Free delivery on orders over 1,000 RON, with room placement and packaging removal.</p>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="section stats-section">
  <div class="container stats-grid">
    <div class="stat-item" data-aos="fade-up" data-aos-delay="0">
      <strong><span class="counter" data-target="500">0</span>+</strong>
      <p>Happy Customers</p>
    </div>
    <div class="stat-item" data-aos="fade-up" data-aos-delay="100">
      <strong><span class="counter" data-target="18">0</span></strong>
      <p>Products</p>
    </div>
    <div class="stat-item" data-aos="fade-up" data-aos-delay="200">
      <strong><span class="counter" data-target="30">0</span>-day</strong>
      <p>Free Returns</p>
    </div>
    <div class="stat-item" data-aos="fade-up" data-aos-delay="300">
      <strong>100%</strong>
      <p>Secure Payment</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section" style="background:var(--color-light);text-align:center;padding:4rem 1rem">
  <div class="container">
    <h2 data-aos="fade-up">Ready to Transform Your Space?</h2>
    <p data-aos="fade-up" data-aos-delay="100" style="margin:.75rem 0 2rem">Browse our collection or let our Room Visualizer do the work.</p>
    <div data-aos="fade-up" data-aos-delay="200">
      <a href="/shop" class="btn btn-primary" style="margin-right:1rem">Shop Now</a>
      <a href="/visualizer" class="btn btn-outline">Room Visualizer</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
