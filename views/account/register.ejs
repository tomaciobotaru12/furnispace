<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="section auth-section">
  <div class="container auth-wrap">
    <div class="auth-card" data-aos="fade-up">
      <h1 class="auth-title">Create Account</h1>
      <p class="auth-subtitle">Join FurniSpace for a faster checkout and order tracking</p>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error" style="margin-bottom:1.25rem"><%= error %></div>
      <% } %>

      <form action="/account/register" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="first_name">First Name</label>
            <input type="text" id="first_name" name="first_name" value="<%= formData.first_name || '' %>" required>
          </div>
          <div class="form-group">
            <label for="last_name">Last Name</label>
            <input type="text" id="last_name" name="last_name" value="<%= formData.last_name || '' %>" required>
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" value="<%= formData.email || '' %>" required>
        </div>
        <div class="form-group">
          <label for="password">Password <span style="font-weight:400;color:var(--color-muted)">(min. 6 characters)</span></label>
          <div class="password-wrap">
            <input type="password" id="password" name="password" required minlength="6">
            <button type="button" class="toggle-pw" onclick="togglePw('password')">Show</button>
          </div>
        </div>
        <div class="form-group">
          <label for="password_confirm">Confirm Password</label>
          <div class="password-wrap">
            <input type="password" id="password_confirm" name="password_confirm" required>
            <button type="button" class="toggle-pw" onclick="togglePw('password_confirm')">Show</button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg" style="width:100%">Create Account</button>
      </form>

      <p class="auth-switch">Already have an account? <a href="/account/login">Log in</a></p>
    </div>
  </div>
</section>

<script>
function togglePw(id) {
  const input = document.getElementById(id);
  const btn = input.nextElementSibling;
  if (input.type === 'password') { input.type = 'text'; btn.textContent = 'Hide'; }
  else { input.type = 'password'; btn.textContent = 'Show'; }
}
</script>

<%- include('../partials/footer') %>
