<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="section account-section">
  <div class="container account-layout">

    <!-- Sidebar -->
    <aside class="account-sidebar">
      <div class="account-avatar">
        <span><%= user.first_name[0] %><%= user.last_name[0] %></span>
      </div>
      <p class="account-sidebar-name"><%= user.first_name %> <%= user.last_name %></p>
      <p class="account-sidebar-email"><%= user.email %></p>
      <nav class="account-nav">
        <a href="/account" class="active">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/account/orders">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          My Orders
        </a>
        <a href="/wishlist">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Wishlist
        </a>
        <a href="/account/logout" style="color:var(--color-error)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Log Out
        </a>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="account-main">
      <h1 class="page-title">My Account</h1>

      <!-- Recent orders -->
      <div class="account-card">
        <div class="account-card-header">
          <h2>Recent Orders</h2>
          <a href="/account/orders" class="btn btn-outline btn-sm">View All</a>
        </div>
        <% if (orders.length) { %>
        <div class="orders-table-wrap">
          <table class="orders-table">
            <thead><tr><th>Order</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr></thead>
            <tbody>
              <% orders.forEach(o => { %>
              <tr>
                <td><strong><%= o.order_number %></strong></td>
                <td><%= new Date(o.created_at).toLocaleDateString('en-GB') %></td>
                <td>—</td>
                <td><%= o.total.toLocaleString('ro-RO') %> RON</td>
                <td><span class="order-status status-<%= o.status %>"><%= o.status %></span></td>
                <td><a href="/account/orders/<%= o.order_number %>" class="btn btn-outline btn-sm">View</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="empty-state" style="padding:2rem 0">
          <p>You haven't placed any orders yet.</p>
          <a href="/shop" class="btn btn-primary" style="margin-top:1rem">Start Shopping</a>
        </div>
        <% } %>
      </div>

      <!-- Profile settings -->
      <div class="account-card" style="margin-top:2rem">
        <div class="account-card-header"><h2>Profile Settings</h2></div>
        <form action="/account/profile" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label>First Name</label>
              <input type="text" name="first_name" value="<%= user.first_name %>" required>
            </div>
            <div class="form-group">
              <label>Last Name</label>
              <input type="text" name="last_name" value="<%= user.last_name %>" required>
            </div>
          </div>
          <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="email" value="<%= user.email %>" required>
          </div>

          <h3 style="font-size:1rem;font-weight:600;margin:1.5rem 0 1rem;padding-top:1.5rem;border-top:1px solid var(--color-border)">
            Change Password <span style="font-weight:400;color:var(--color-muted);font-size:.85rem">(leave blank to keep current)</span>
          </h3>
          <div class="form-group">
            <label>Current Password</label>
            <input type="password" name="current_password">
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>New Password</label>
              <input type="password" name="new_password" minlength="6">
            </div>
            <div class="form-group">
              <label>Confirm New Password</label>
              <input type="password" name="confirm_password">
            </div>
          </div>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
      </div>
    </div>

  </div>
</section>

<%- include('../partials/footer') %>
