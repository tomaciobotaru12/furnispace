<div class="product-card" data-aos="fade-up" data-aos-delay="<%= typeof delay !== 'undefined' ? delay : 0 %>">
  <div class="product-card-img-wrap">
    <a href="/product/<%= product.slug %>">
      <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" decoding="async">
    </a>
    <% if (product.sale_price) { %>
    <span class="badge-sale">Sale</span>
    <% } else if (product.stock > 0 && product.stock <= 5) { %>
    <span class="badge-low-stock">Only <%= product.stock %> left</span>
    <% } %>
    <button class="wishlist-btn" data-id="<%= product.id %>" data-name="<%= product.name %>" data-price="<%= product.sale_price || product.price %>" data-image="<%= product.image %>" aria-label="Add to wishlist">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>
    <div class="eco-badge">
      <% for (let e = 1; e <= 5; e++) { %>
      <span class="eco-dot <%= e <= product.eco_score ? 'active' : '' %>"></span>
      <% } %>
      <span class="eco-label">Eco</span>
    </div>
  </div>
  <div class="product-card-body">
    <h3><a href="/product/<%= product.slug %>"><%= product.name %></a></h3>
    <div class="product-price">
      <% if (product.sale_price) { %>
      <span class="price-sale"><%= product.sale_price.toLocaleString('ro-RO') %> RON</span>
      <span class="price-original"><%= product.price.toLocaleString('ro-RO') %> RON</span>
      <% } else { %>
      <span class="price-regular"><%= product.price.toLocaleString('ro-RO') %> RON</span>
      <% } %>
    </div>
    <% if (product.stock > 0) { %>
    <form action="/cart/add" method="POST" class="add-to-cart-form">
      <input type="hidden" name="product_id" value="<%= product.id %>">
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
    </form>
    <% } else { %>
    <button class="btn btn-outline btn-sm" disabled style="opacity:.5;cursor:not-allowed">Out of Stock</button>
    <% } %>
  </div>
</div>
