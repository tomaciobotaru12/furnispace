<header class="site-header" id="site-header">
  <div class="header-inner container">
    <a href="/" class="site-logo">Furni<span>Space</span></a>

    <nav class="primary-nav" id="primary-nav">
      <ul>
        <li><a href="/shop">Shop</a>
          <ul class="sub-menu">
            <li><a href="/shop/living-room">🛋️ Living Room</a></li>
            <li><a href="/shop/bedroom">🛏️ Bedroom</a></li>
            <li><a href="/shop/dining">🍽️ Dining</a></li>
            <li><a href="/shop/office">💼 Office</a></li>
            <li><a href="/shop/lighting">💡 Lighting</a></li>
            <li><a href="/shop/storage">🗄️ Storage</a></li>
          </ul>
        </li>
        <li><a href="/visualizer">Room Visualizer</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <div class="header-actions">
      <a href="/wishlist" class="header-icon wishlist-icon" title="Wishlist">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span class="wishlist-count" id="wishlist-count" style="display:none">0</span>
      </a>

      <!-- Account icon -->
      <div class="header-icon account-menu-wrap">
        <button class="account-menu-btn" id="account-menu-btn" aria-label="Account">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <% if (currentUser) { %><span class="account-name-label"><%= currentUser.name %></span><% } %>
        </button>
        <div class="account-dropdown" id="account-dropdown">
          <% if (currentUser) { %>
          <div class="account-dropdown-header">Hi, <strong><%= currentUser.name %></strong></div>
          <a href="/account">My Account</a>
          <a href="/account/orders">My Orders</a>
          <a href="/account/logout" class="account-logout">Log Out</a>
          <% } else { %>
          <a href="/account/login" class="account-dropdown-cta">Log In</a>
          <a href="/account/register">Create Account</a>
          <% } %>
        </div>
      </div>

      <a href="/cart" class="header-icon cart-icon" title="Cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span class="cart-count" id="cart-count"><%= cartCount %></span>
      </a>
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile nav drawer -->
<div class="mobile-nav-backdrop" id="mobile-nav-backdrop"></div>
<nav class="mobile-nav" id="mobile-nav">
  <button class="mobile-nav-close" id="mobile-nav-close" aria-label="Close menu">✕</button>
  <ul>
    <li><a href="/shop">Shop All</a></li>
    <li><a href="/shop/living-room">🛋️ Living Room</a></li>
    <li><a href="/shop/bedroom">🛏️ Bedroom</a></li>
    <li><a href="/shop/dining">🍽️ Dining</a></li>
    <li><a href="/shop/office">💼 Office</a></li>
    <li><a href="/shop/lighting">💡 Lighting</a></li>
    <li><a href="/shop/storage">🗄️ Storage</a></li>
    <li><a href="/visualizer">Room Visualizer</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/contact">Contact</a></li>
    <li><a href="/wishlist">Wishlist</a></li>
    <li><a href="/cart">Cart (<%= cartCount %>)</a></li>
  </ul>
</nav>

<% if (success && success.length) { %>
<div class="flash flash-success"><%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
<div class="flash flash-error"><%= error[0] %></div>
<% } %>
