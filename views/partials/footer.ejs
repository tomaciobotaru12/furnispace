        </a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Shop</h4>
      <ul>
        <li><a href="/shop/living-room">Living Room</a></li>
        <li><a href="/shop/bedroom">Bedroom</a></li>
        <li><a href="/shop/dining">Dining</a></li>
        <li><a href="/shop/office">Office</a></li>
        <li><a href="/shop/lighting">Lighting</a></li>
        <li><a href="/shop/storage">Storage</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Help</h4>
      <ul>
        <li><a href="/about">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/wishlist">Wishlist</a></li>
        <li><a href="/visualizer">Room Visualizer</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Returns &amp; Refunds</a></li>
      </ul>
    </div>

    <div class="footer-col footer-newsletter">
      <h4>Stay in the loop</h4>
      <p>Get new arrivals and exclusive offers straight to your inbox.</p>
      <form class="newsletter-form" id="newsletter-form">
        <input type="email" name="email" placeholder="your@email.com" required>
        <button type="submit">Subscribe</button>
      </form>
      <p class="newsletter-msg" id="newsletter-msg"></p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; <%= new Date().getFullYear() %> FurniSpace. All rights reserved.</p>
      <div class="payment-badges">
        <span class="badge">VISA</span>
        <span class="badge">Mastercard</span>
        <span class="badge">Stripe</span>
        <span class="badge">PayPal</span>
      </div>
    </div>
  </div>
</footer>

<!-- Floating cart bubble (hide on cart/checkout pages) -->
<% if (typeof hideCartBubble === 'undefined' || !hideCartBubble) { %>
<a href="/cart" class="cart-bubble" id="cart-bubble" style="<%= cartCount === 0 ? 'display:none' : '' %>">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
  <span class="cart-bubble-count"><%= cartCount %></span>
</a>
<% } %>

<!-- AOS -->
<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<!-- Main JS -->
<script src="/js/main.js"></script>
</body>
</html>
